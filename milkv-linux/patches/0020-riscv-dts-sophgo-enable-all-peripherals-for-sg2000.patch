From 5ffd19808b5b2c9b6d79d4204c5d90b370e84fb2 Mon Sep 17 00:00:00 2001
From: queenkjuul <queenkjuul@pm.me>
Date: Tue, 24 Mar 2026 09:28:10 +0000
Subject: [PATCH 20/37] riscv: dts: sophgo: enable all peripherals for sg2000

---
 .../boot/dts/sophgo/sg2000-milkv-duo-s.dts    | 40 +++++++++++++++++++
 1 file changed, 40 insertions(+)

diff --git a/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts b/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
index d320b5c4ad5c..779a132f4acd 100644
--- a/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
+++ b/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
@@ -14,9 +14,13 @@ memory@80000000 {
 	};
 
 	aliases {
+		i2c1 = &i2c1;
+		i2c2 = &i2c2;
+		i2c3 = &i2c3;
 		i2c4 = &i2c4;
 		mmc0 = &sdhci0;
 		serial0 = &uart0;
+		spi0 = &spi0;
 		spi3 = &spi3;
 	};
 
@@ -47,6 +51,18 @@ &gmac0 {
 	status = "okay";
 };
 
+&i2c1 {
+	status = "okay";
+};
+
+&i2c2 {
+	status = "okay";
+};
+
+&i2c3 {
+	status = "okay";
+};
+
 &i2c4 {
 	status = "okay";
 };
@@ -75,6 +91,18 @@ &sdhci1 {
 	status = "okay";
 };
 
+&spi0 {
+	status = "okay";
+};
+
+&spi1 {
+	status = "okay";
+};
+
+&spi2 {
+	status = "okay";
+};
+
 &spi3 {
 	status = "okay";
 };
@@ -83,6 +111,18 @@ &uart0 {
 	status = "okay";
 };
 
+&uart1 {
+	status = "okay";
+};
+
+&uart2 {
+	status = "okay";
+};
+
+&uart3 {
+	status = "okay";
+};
+
 &uart4 {
 	status = "okay";
 };
