From 6be8d6e368220b97b15637e9b8889e12fd81fe16 Mon Sep 17 00:00:00 2001
From: queenkjuul <queenkjuul@pm.me>
Date: Tue, 10 Mar 2026 06:08:10 +0000
Subject: [PATCH 14/37] riscv64: dts: sophgo: use mdio-mux driver for Sophgo
 CV18xx ethernet

---
 arch/riscv/boot/dts/sophgo/cv180x.dtsi | 15 +++++++--------
 1 file changed, 7 insertions(+), 8 deletions(-)

diff --git a/arch/riscv/boot/dts/sophgo/cv180x.dtsi b/arch/riscv/boot/dts/sophgo/cv180x.dtsi
index 58a693d1fba0..649dfd4d6c91 100644
--- a/arch/riscv/boot/dts/sophgo/cv180x.dtsi
+++ b/arch/riscv/boot/dts/sophgo/cv180x.dtsi
@@ -85,19 +85,18 @@ rst: reset-controller@3003000 {
 			#reset-cells = <1>;
 		};
 
-		mdio: mdio-mux@3009800 {
-			compatible = "mdio-mux-mmioreg", "mdio-mux";
-			reg = <0x3009800 0x4>;
+		mdio: mdio-mux@3009000 {
+			compatible = "sophgo,cv1800b-mdio-mux";
+			reg = <0x3009000 0x1000>;
 			#address-cells = <1>;
 			#size-cells = <0>;
 			mdio-parent-bus = <&gmac0_mdio>;
-			mux-mask = <0x80>;
 			status = "disabled";
 
-			internal_mdio: mdio@0 {
+			internal_mdio: mdio@1 {
 				#address-cells = <1>;
 				#size-cells = <0>;
-				reg = <0>;
+				reg = <1>;
 
 				internal_ephy: phy@0 {
 					compatible = "ethernet-phy-ieee802.3-c22";
@@ -105,10 +104,10 @@ internal_ephy: phy@0 {
 				};
 			};
 
-			external_mdio: mdio@80 {
+			external_mdio: mdio@0 {
 				#address-cells = <1>;
 				#size-cells = <0>;
-				reg = <0x80>;
+				reg = <0>;
 			};
 		};
 
-- 
2.34.1

