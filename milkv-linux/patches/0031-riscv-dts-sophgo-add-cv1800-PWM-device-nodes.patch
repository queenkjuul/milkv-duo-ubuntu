From 4a4be32044d52e55d30898ba5fb5d4470164380b Mon Sep 17 00:00:00 2001
From: queenkjuul <queenkjuul@pm.me>
Date: Mon, 13 Apr 2026 17:04:35 +0000
Subject: [PATCH 31/37] riscv: dts: sophgo: add cv1800 PWM device nodes

---
 arch/riscv/boot/dts/sophgo/cv180x.dtsi | 32 ++++++++++++++++++++++++++
 1 file changed, 32 insertions(+)

diff --git a/arch/riscv/boot/dts/sophgo/cv180x.dtsi b/arch/riscv/boot/dts/sophgo/cv180x.dtsi
index 2175c59f6866..29941fed1dc2 100644
--- a/arch/riscv/boot/dts/sophgo/cv180x.dtsi
+++ b/arch/riscv/boot/dts/sophgo/cv180x.dtsi
@@ -210,6 +210,38 @@ ephy_txitune: ephy-txitune@24 {
 			};
     };
 
+		pwm0: pwm@3060000 {
+			compatible = "sophgo,cv1800-pwm";
+			reg = <0x3060000 0x1000>;
+			clocks = <&clk CLK_PWM>;
+			#pwm-cells = <3>;
+			status = "disabled";
+		};
+
+		pwm1: pwm@3061000 {
+			compatible = "sophgo,cv1800-pwm";
+			reg = <0x3061000 0x1000>;
+			clocks = <&clk CLK_PWM>;
+			#pwm-cells = <3>;
+			status = "disabled";
+		};
+
+		pwm2: pwm@3062000 {
+			compatible = "sophgo,cv1800-pwm";
+			reg = <0x3062000 0x1000>;
+			clocks = <&clk CLK_PWM>;
+			#pwm-cells = <3>;
+			status = "disabled";
+		};
+
+		pwm3: pwm@3063000 {
+			compatible = "sophgo,cv1800-pwm";
+			reg = <0x3063000 0x1000>;
+			clocks = <&clk CLK_PWM>;
+			#pwm-cells = <3>;
+			status = "disabled";
+		};
+
 		soc_temp: thermal-sensor@30e0000 {
 			compatible = "sophgo,cv1800-thermal";
 			reg = <0x30e0000 0x100>;
-- 
2.34.1

