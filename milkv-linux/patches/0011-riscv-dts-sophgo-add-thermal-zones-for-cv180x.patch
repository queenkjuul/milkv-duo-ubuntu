From 3d0fdb315fe6d4dea893a523e16ee0e6886f7d3c Mon Sep 17 00:00:00 2001
From: queenkjuul <queenkjuul@pm.me>
Date: Wed, 18 Mar 2026 01:29:11 +0000
Subject: [PATCH 11/37] riscv: dts: sophgo: add thermal zones for cv180x

---
 arch/riscv/boot/dts/sophgo/cv180x.dtsi | 28 ++++++++++++++++++++++++++
 arch/riscv/boot/dts/sophgo/sg2000.dtsi |  2 ++
 2 files changed, 30 insertions(+)

diff --git a/arch/riscv/boot/dts/sophgo/cv180x.dtsi b/arch/riscv/boot/dts/sophgo/cv180x.dtsi
index c6489c2e99e3..58a693d1fba0 100644
--- a/arch/riscv/boot/dts/sophgo/cv180x.dtsi
+++ b/arch/riscv/boot/dts/sophgo/cv180x.dtsi
@@ -19,6 +19,34 @@ osc: oscillator {
 		#clock-cells = <0>;
 	};
 
+	thermal-zones {
+		soc-thermal {
+			polling-delay-passive   = <1000>;
+			polling-delay           = <1000>;
+			thermal-sensors         = <&soc_temp>;
+
+			trips {
+				soc_passive: soc-passive {
+					temperature     = <75000>;
+					hysteresis      = <5000>;
+					type            = "passive";
+				};
+
+				soc_hot: soc-hot {
+					temperature     = <85000>;
+					hysteresis      = <5000>;
+					type            = "hot";
+				};
+
+				soc_critical: soc-critical {
+					temperature     = <100000>;
+					hysteresis      = <0>;
+					type            = "critical";
+				};
+			};
+		};
+	};
+
 	soc {
 		compatible = "simple-bus";
 		#address-cells = <1>;
diff --git a/arch/riscv/boot/dts/sophgo/sg2000.dtsi b/arch/riscv/boot/dts/sophgo/sg2000.dtsi
index 412adacc0057..3c3c95c13349 100644
--- a/arch/riscv/boot/dts/sophgo/sg2000.dtsi
+++ b/arch/riscv/boot/dts/sophgo/sg2000.dtsi
@@ -16,6 +16,8 @@ memory@80000000 {
 		reg = <0x80000000 0x10000000>;
 	};
 
+	};
+
 	soc {
 		interrupt-parent = <&plic>;
 		dma-noncoherent;
-- 
2.34.1

