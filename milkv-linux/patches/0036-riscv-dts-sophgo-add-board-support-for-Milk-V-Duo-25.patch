From 71e85fad96ebdab0afc02374b0216186a6bd1dfe Mon Sep 17 00:00:00 2001
From: queenkjuul <queenkjuul@pm.me>
Date: Fri, 24 Apr 2026 20:32:54 +0000
Subject: [PATCH 36/37] riscv: dts: sophgo: add board support for Milk-V Duo
 256M (sg2002)

---
 arch/riscv/boot/dts/sophgo/Makefile           |   1 +
 .../boot/dts/sophgo/sg2002-milkv-duo-256m.dts | 150 ++++++++++++++++++
 arch/riscv/boot/dts/sophgo/sg2002.dtsi        |  21 +++
 3 files changed, 172 insertions(+)
 create mode 100644 arch/riscv/boot/dts/sophgo/sg2002-milkv-duo-256m.dts

diff --git a/arch/riscv/boot/dts/sophgo/Makefile b/arch/riscv/boot/dts/sophgo/Makefile
index 58cc6b70d8de..d6c65e93132d 100644
--- a/arch/riscv/boot/dts/sophgo/Makefile
+++ b/arch/riscv/boot/dts/sophgo/Makefile
@@ -2,6 +2,7 @@
 dtb-$(CONFIG_ARCH_SOPHGO) += cv1800b-milkv-duo.dtb
 dtb-$(CONFIG_ARCH_SOPHGO) += cv1812h-huashan-pi.dtb
 dtb-$(CONFIG_ARCH_SOPHGO) += sg2000-milkv-duo-s.dtb
+dtb-$(CONFIG_ARCH_SOPHGO) += sg2002-milkv-duo-256m.dtb
 dtb-$(CONFIG_ARCH_SOPHGO) += sg2002-licheerv-nano-b.dtb
 dtb-$(CONFIG_ARCH_SOPHGO) += sg2042-milkv-pioneer.dtb
 dtb-$(CONFIG_ARCH_SOPHGO) += sg2042-evb-v1.dtb
diff --git a/arch/riscv/boot/dts/sophgo/sg2002-milkv-duo-256m.dts b/arch/riscv/boot/dts/sophgo/sg2002-milkv-duo-256m.dts
new file mode 100644
index 000000000000..3d06cfac6a10
--- /dev/null
+++ b/arch/riscv/boot/dts/sophgo/sg2002-milkv-duo-256m.dts
@@ -0,0 +1,150 @@
+// SPDX-License-Identifier: (GPL-2.0 OR MIT)
+
+/dts-v1/;
+
+#include "sg2002.dtsi"
+
+/ {
+	model = "Milk-V Duo 256M";
+	compatible = "milkv,duo-256m", "sophgo,sg2002";
+
+	aliases {
+		pwm1 = &pwm1;
+		pwm2 = &pwm2;
+		pwm3 = &pwm3;
+		i2c1 = &i2c1;
+		i2c2 = &i2c2;
+		i2c3 = &i2c3;
+		mmc0 = &sdhci0;
+		serial0 = &uart0;
+		spi2 = &spi2;
+	};
+
+	chosen {
+		stdout-path = "serial0:115200n8";
+	};
+};
+
+&osc {
+	clock-frequency = <25000000>;
+};
+
+&dmac {
+	status = "okay";
+};
+
+&emmc {
+	bus-width = <4>;
+	no-1-8-v;
+	cap-mmc-hw-reset;
+	no-sd;
+	no-sdio;
+	non-removable;
+	status = "okay";
+};
+
+&gmac0 {
+	status = "okay";
+};
+
+&efuse {
+	status = "okay";
+};
+
+&pwm1 {
+	status = "okay";
+};
+
+&pwm2 {
+	status = "okay";
+};
+
+&i2c1 {
+	status = "okay";
+};
+
+&i2c2 {
+	status = "okay";
+};
+
+&i2c3 {
+	status = "okay";
+};
+
+&mdio {
+	status = "okay";
+};
+
+&saradc {
+	status = "okay";
+};
+
+&sdhci0 {
+	bus-width = <4>;
+	no-1-8-v;
+	disable-wp;
+	status = "okay";
+};
+
+&sdhci1 {
+	bus-width = <4>;
+	cap-sdio-irq;
+	no-mmc;
+	no-sd;
+	non-removable;
+	status = "okay";
+};
+
+&spi2 {
+	status = "okay";
+};
+
+&uart0 {
+	status = "okay";
+};
+
+&uart1 {
+	status = "okay";
+};
+
+&uart2 {
+	status = "okay";
+};
+
+&uart3 {
+	status = "okay";
+};
+
+&usb {
+	dr_mode = "otg";
+	status = "okay";
+};
+
+&wdt {
+	status = "okay";
+};
+
+&i2s0 {
+	status = "okay";
+	#sound-dai-cells = <0>;
+};
+
+&i2s3 {
+	status = "okay";
+	#sound-dai-cells = <0>;
+};
+
+&int_dac {
+	status = "okay";
+};
+
+&int_adc {
+	status = "okay";
+	#sound-dai-cells = <0>;
+	/delete-property/ mute-gpio-l;
+	/delete-property/ mute-gpio-r;
+};
+
+&remoteproc {
+	status = "okay";
+};
\ No newline at end of file
diff --git a/arch/riscv/boot/dts/sophgo/sg2002.dtsi b/arch/riscv/boot/dts/sophgo/sg2002.dtsi
index 98001cce238e..ca386cac1c2d 100644
--- a/arch/riscv/boot/dts/sophgo/sg2002.dtsi
+++ b/arch/riscv/boot/dts/sophgo/sg2002.dtsi
@@ -19,6 +19,27 @@ memory@80000000 {
 		reg = <0x80000000 0x10000000>;
 	};
 
+	reserved-memory {
+    #address-cells = <1>;
+    #size-cells = <1>;
+    ranges;
+
+    coprocessor_rtos: region@8fe00000 {
+        no-map;
+        reg = <0x8fe00000 0x200000>;
+    };
+	};
+
+	remoteproc: c906l-rproc {
+		compatible = "sophgo,cv1800b-c906l";
+		firmware-name = "cvirtos.elf";
+		mboxes = <&mailbox 0 2>, <&mailbox 1 1>;
+		mbox-names = "tx", "rx";
+		memory-region = <&coprocessor_rtos>;
+		resets = <&rst 294>;
+		sophgo,syscon = <&syscon>;
+	};
+
 	soc {
 		interrupt-parent = <&plic>;
 		dma-noncoherent;
-- 
2.34.1

