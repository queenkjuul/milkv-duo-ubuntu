From d38a50f1426e830664d9a744a21cbf7b46b7e1aa Mon Sep 17 00:00:00 2001
From: queenkjuul <queenkjuul@pm.me>
Date: Wed, 18 Mar 2026 01:29:11 +0000
Subject: [PATCH 10/20] riscv: dts: sophgo: add thermal zones for sg2000

---
 arch/riscv/boot/dts/sophgo/sg2000.dtsi | 28 ++++++++++++++++++++++++++
 1 file changed, 28 insertions(+)

diff --git a/arch/riscv/boot/dts/sophgo/sg2000.dtsi b/arch/riscv/boot/dts/sophgo/sg2000.dtsi
index 412adacc0057..74fc3e9a6007 100644
--- a/arch/riscv/boot/dts/sophgo/sg2000.dtsi
+++ b/arch/riscv/boot/dts/sophgo/sg2000.dtsi
@@ -16,6 +16,34 @@ memory@80000000 {
 		reg = <0x80000000 0x10000000>;
 	};
 
+	thermal-zones {
+		soc-thermal {
+			polling-delay-passive   = <1000>;
+			polling-delay           = <1000>;
+			thermal-sensors         = <&soc_temp>;
+
+			trips {
+				soc_passive: soc-passive {
+					temperature     = <75000>;
+					hysteresis      = <5000>;
+					type            = "passive";
+				};
+
+				soc_hot: soc-hot {
+					temperature     = <85000>;
+					hysteresis      = <5000>;
+					type            = "hot";
+				};
+
+				soc_critical: soc-critical {
+					temperature     = <100000>;
+					hysteresis      = <0>;
+					type            = "critical";
+				};
+			};
+		};
+	};
+
 	soc {
 		interrupt-parent = <&plic>;
 		dma-noncoherent;
-- 
2.34.1

