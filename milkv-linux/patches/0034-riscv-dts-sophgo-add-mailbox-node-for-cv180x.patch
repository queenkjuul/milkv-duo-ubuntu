From 51d02f45bf45b72c49f7f227291504bdd5ff7546 Mon Sep 17 00:00:00 2001
From: queenkjuul <queenkjuul@pm.me>
Date: Fri, 24 Apr 2026 20:30:19 +0000
Subject: [PATCH 34/37] riscv: dts: sophgo: add mailbox node for cv180x

---
 arch/riscv/boot/dts/sophgo/cv180x.dtsi | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/arch/riscv/boot/dts/sophgo/cv180x.dtsi b/arch/riscv/boot/dts/sophgo/cv180x.dtsi
index 29941fed1dc2..958e945f8268 100644
--- a/arch/riscv/boot/dts/sophgo/cv180x.dtsi
+++ b/arch/riscv/boot/dts/sophgo/cv180x.dtsi
@@ -48,6 +48,15 @@ soc_critical: soc-critical {
 		};
 	};
 
+	mailbox: mailbox@1900000 {
+		compatible = "sophgo,cv1800b-mailbox";
+		reg = <0x01900000 0x1000>;
+		interrupts = <101 IRQ_TYPE_LEVEL_HIGH>;
+		interrupt-parent = <&plic>;
+		#mbox-cells = <2>;
+		status = "okay";
+	};
+
 	soc {
 		compatible = "simple-bus";
 		#address-cells = <1>;
-- 
2.34.1

