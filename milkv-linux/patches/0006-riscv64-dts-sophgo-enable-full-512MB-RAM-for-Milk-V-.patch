From 0ad52066573dbdc9443caba5d0ab4e42641fb71f Mon Sep 17 00:00:00 2001
From: queenkjuul <queenkjuul@pm.me>
Date: Sun, 29 Mar 2026 22:42:52 +0000
Subject: [PATCH 06/37] riscv64: dts: sophgo: enable full 512MB RAM for Milk-V
 Duo S (sg2000)

---
 arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts b/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
index 174c194e1301..941e77ae2766 100644
--- a/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
+++ b/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
@@ -8,6 +8,11 @@ / {
 	model = "Milk-V Duo S";
 	compatible = "milkv,duo-s", "sophgo,sg2000";
 
+	memory@80000000 {
+		device_type = "memory";
+		reg = <0x80000000 0x20000000>;
+	};
+
 	aliases {
 		i2c4 = &i2c4;
 		mmc0 = &sdhci0;
-- 
2.34.1

