From e6175f7b65c239acd7c22ce53d6c77f5a6c82c6f Mon Sep 17 00:00:00 2001
From: queenkjuul <queenkjuul@pm.me>
Date: Mon, 13 Apr 2026 17:14:42 +0000
Subject: [PATCH 33/37] riscv: dts: sophgo: enable I2S devices for
 sg2000-milkv-duo-s

---
 .../boot/dts/sophgo/sg2000-milkv-duo-s.dts    | 68 +++++++++++++++++++
 1 file changed, 68 insertions(+)

diff --git a/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts b/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
index 256bea50ff8c..9724653ea493 100644
--- a/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
+++ b/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
@@ -31,6 +31,45 @@ aliases {
 	chosen {
 		stdout-path = "serial0:115200n8";
 	};
+
+	sound_card {
+		compatible = "simple-audio-card";
+		simple-audio-card,name = "Milk-V Duo S Built-in Audio";
+		simple-audio-card,format = "i2s";
+
+		#address-cells = <1>;
+		#size-cells = <0>;
+
+		simple-audio-card,dai-link@0 {
+			reg = <0>;
+			format = "i2s";
+			bitclock-master = <&i2s3_cpu>;
+			frame-master = <&i2s3_cpu>;
+
+			i2s3_cpu: cpu {
+				sound-dai = <&i2s3>;
+			};
+			codec {
+				sound-dai = <&int_dac>;
+				mclk-fs = <256>;
+			};
+		};
+
+		simple-audio-card,dai-link@1 {
+			reg = <1>;
+			format = "i2s";
+			bitclock-master = <&i2s0_cpu>;
+			frame-master = <&i2s0_cpu>;
+
+			i2s0_cpu: cpu {
+				sound-dai = <&i2s0>;
+			};
+			codec {
+				sound-dai = <&int_adc>;
+				mclk-fs = <256>;
+			};
+		};
+	};
 };
 
 &osc {
@@ -159,3 +198,32 @@ &usb {
 &wdt {
 	status = "okay";
 };
+
+&i2s0 {
+	status = "okay";
+	#sound-dai-cells = <0>;
+};
+
+&i2s1 {
+	status = "disabled";
+};
+
+&i2s2 {
+	status = "disabled";
+};
+
+&i2s3 {
+	status = "okay";
+	#sound-dai-cells = <0>;
+};
+
+&int_dac {
+	status = "okay";
+};
+
+&int_adc {
+	status = "okay";
+	#sound-dai-cells = <0>;
+	/delete-property/ mute-gpio-l;
+	/delete-property/ mute-gpio-r;
+};
\ No newline at end of file
-- 
2.34.1

