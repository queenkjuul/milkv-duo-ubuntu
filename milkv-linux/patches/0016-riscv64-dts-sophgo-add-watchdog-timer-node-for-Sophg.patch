From ebd90a66254a80995a3c73b66d52a27d307f1bfd Mon Sep 17 00:00:00 2001
From: queenkjuul <queenkjuul@pm.me>
Date: Thu, 12 Mar 2026 05:51:30 +0000
Subject: [PATCH 16/37] riscv64: dts: sophgo: add watchdog timer node for
 Sophgo cv180x

---
 arch/riscv/boot/dts/sophgo/cv180x.dtsi | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/arch/riscv/boot/dts/sophgo/cv180x.dtsi b/arch/riscv/boot/dts/sophgo/cv180x.dtsi
index 649dfd4d6c91..285c1f26afe4 100644
--- a/arch/riscv/boot/dts/sophgo/cv180x.dtsi
+++ b/arch/riscv/boot/dts/sophgo/cv180x.dtsi
@@ -85,6 +85,15 @@ rst: reset-controller@3003000 {
 			#reset-cells = <1>;
 		};
 
+		wdt: watchdog@3010000 {
+			compatible = "snps,dw-wdt";
+			reg = <0x03010000 0x100>;
+			snps,watchdog-tops = <0x0fffffff 0x1fffffff 0x3fffffff 0x7fffffff 0x0fffffff 0x1fffffff 0x3fffffff 0x7fffffff 0x0fffffff 0x1fffffff 0x3fffffff 0x7fffffff 0x0fffffff 0x1fffffff 0x3fffffff 0x7fffffff>;
+			interrupts = <58 4>;
+			clocks = <&osc>;
+			resets = <&rst RST_WDT1>;
+		};
+
 		mdio: mdio-mux@3009000 {
 			compatible = "sophgo,cv1800b-mdio-mux";
 			reg = <0x3009000 0x1000>;
-- 
2.34.1

