From c5321b94d28b36ca2ae6f1b2cb97caa40d5e7bc7 Mon Sep 17 00:00:00 2001
From: queenkjuul <queenkjuul@pm.me>
Date: Fri, 24 Apr 2026 20:30:49 +0000
Subject: [PATCH 35/37] riscv: dts: sophgo: add remoteproc nodes for sg2000

---
 .../boot/dts/sophgo/sg2000-milkv-duo-s.dts    |  4 ++++
 arch/riscv/boot/dts/sophgo/sg2000.dtsi        | 19 +++++++++++++++++++
 2 files changed, 23 insertions(+)

diff --git a/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts b/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
index 9724653ea493..e25a1abeb1d9 100644
--- a/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
+++ b/arch/riscv/boot/dts/sophgo/sg2000-milkv-duo-s.dts
@@ -226,4 +226,8 @@ &int_adc {
 	#sound-dai-cells = <0>;
 	/delete-property/ mute-gpio-l;
 	/delete-property/ mute-gpio-r;
+};
+
+&remoteproc {
+	status = "okay";
 };
\ No newline at end of file
diff --git a/arch/riscv/boot/dts/sophgo/sg2000.dtsi b/arch/riscv/boot/dts/sophgo/sg2000.dtsi
index 3c3c95c13349..f4a6ba7707c5 100644
--- a/arch/riscv/boot/dts/sophgo/sg2000.dtsi
+++ b/arch/riscv/boot/dts/sophgo/sg2000.dtsi
@@ -16,6 +16,25 @@ memory@80000000 {
 		reg = <0x80000000 0x10000000>;
 	};
 
+	reserved-memory {
+    #address-cells = <1>;
+    #size-cells = <1>;
+    ranges;
+
+    coprocessor_rtos: region@8fe00000 {
+        no-map;
+        reg = <0x9fe00000 0x200000>;
+    };
+	};
+
+	remoteproc: c906l-rproc {
+		compatible = "sophgo,cv1800b-c906l";
+		firmware-name = "cvirtos.elf";
+		mboxes = <&mailbox 0 2>, <&mailbox 1 1>;
+		mbox-names = "tx", "rx";
+		memory-region = <&coprocessor_rtos>;
+		resets = <&rst 294>;
+		sophgo,syscon = <&syscon>;
 	};
 
 	soc {
-- 
2.34.1

