#!/bin/sh
set -e

DEVICE="duos"
LIBEXEC_DIR="/usr/libexec/milkv"
TARGET_LINK="/usr/bin/milkv-usb-init"

usage() {
    echo "Usage: $(basename "$0") <mode>"
    echo "Available modes for $DEVICE:"
    ls $LIBEXEC_DIR/${DEVICE}-usb-* 2>/dev/null | sed "s/.*${DEVICE}-usb-\(.*\)/\1/"
    exit 1
}

if [ -z "$1" ]; then
    usage
fi

MODE="$1"
SOURCE_SCRIPT="$LIBEXEC_DIR/${DEVICE}-usb-${MODE}"

if [ ! -f "$SOURCE_SCRIPT" ]; then
    echo "Error: Mode '$MODE' not found at $SOURCE_SCRIPT"
    usage
fi

if [ "$(id -u)" -ne 0 ]; then
    echo "Error: Please run as root (sudo)"
    exit 1
fi

ln -sf "$SOURCE_SCRIPT" "$TARGET_LINK"
echo "Success: $DEVICE USB mode set to $MODE."
echo "Run 'systemctl restart milkv-usb' or 'milkv-usb-init' to apply."