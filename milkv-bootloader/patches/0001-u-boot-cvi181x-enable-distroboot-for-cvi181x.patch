From 1b43f1692f0cb9d22cdc2fb8172e687831738455 Mon Sep 17 00:00:00 2001
From: queenkjuul <queenkjuul@pm.me>
Date: Mon, 30 Mar 2026 06:00:26 +0000
Subject: [PATCH 1/7] u-boot: cvi181x: enable distroboot for cvi181x

---
 u-boot-2021.10/include/configs/cv181x-asic.h | 22 +++++++++++++++++---
 1 file changed, 19 insertions(+), 3 deletions(-)

diff --git a/u-boot-2021.10/include/configs/cv181x-asic.h b/u-boot-2021.10/include/configs/cv181x-asic.h
index acf5082d2..e5328b499 100644
--- a/u-boot-2021.10/include/configs/cv181x-asic.h
+++ b/u-boot-2021.10/include/configs/cv181x-asic.h
@@ -9,6 +9,7 @@
 #define __CV181X_ASIC_H__
 
 #include <../../../board/cvitek/cv181x/cv181x_reg.h>
+#include <config_distro_bootcmd.h>
 
 /* defined in cvipart.h */
 #undef CONFIG_ENV_OFFSET
@@ -185,6 +186,11 @@
 #define CONFIG_GATEWAYIP		192.168.0.11
 #define CONFIG_SERVERIP			192.168.56.101
 
+#define BOOT_TARGET_DEVICES(func) \
+	func(MMC, mmc, 0) \
+	func(DHCP, dhcp, 0) \
+	func(PXE, pxe, na)
+
 #ifdef CONFIG_USE_DEFAULT_ENV
 /* The following Settings are chip dependent */
 /******************************************************************************/
@@ -266,7 +272,17 @@
 		"root=" ROOTARGS "\0" \
 		"sdboot=" SD_BOOTM_COMMAND "\0" \
 		"othbootargs=" OTHERBOOTARGS "\0" \
-		PARTS_OFFSET
+		"kernel_addr_r=" __stringify(CONFIG_SYS_TEXT_BASE) "\0" \
+		"fdt_addr_r=0x82200000\0" \
+		"fdtoverlay_addr_r=0x82300000\0" \
+		"pxefile_addr_r=0x82400000\0" \
+		"scriptaddr=0x82500000\0" \
+		"ramdisk_addr_r=0x84000000\0" \
+		"kernel_comp_addr_r=" __stringify(CVIMMAP_UIMAG_ADDR) "\0" \
+		"kernel_comp_size=" __stringify(CVIMMAP_UIMAG_SIZE) "\0" \
+		"fdtfile=" FDT_NO ".dtb\0" \
+		PARTS_OFFSET \
+		BOOTENV
 
 /********************************************************************************/
 	/* UBOOT_VBOOT commands */
@@ -313,10 +329,10 @@
 		#ifdef CONFIG_ENABLE_ALIOS_UPDATE
 			#define CONFIG_BOOTCOMMAND	"cvi_update_rtos"
 		#else
-			#define CONFIG_BOOTCOMMAND	SHOWLOGOCMD "cvi_update || run norboot || run nandboot ||run emmcboot"
+			#define CONFIG_BOOTCOMMAND	"cvi_update || run distro_bootcmd || run norboot || run nandboot ||run emmcboot"
 		#endif
 	#else
-		#define CONFIG_BOOTCOMMAND	SHOWLOGOCMD "run sdboot"
+		#define CONFIG_BOOTCOMMAND	"run distro_bootcmd || run sdboot"
 	#endif
 
 	#if defined(CONFIG_NAND_SUPPORT)
-- 
2.34.1

