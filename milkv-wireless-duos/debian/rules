#!/usr/bin/make -f

%:
	dh $@

override_dh_fixperms:
	dh_fixperms
	chmod +x debian/milkv-wireless-duos/usr/bin/*

override_dh_installsystemd:
	dh_installsystemd --name=milkv-wifi --no-stop-on-upgrade
	dh_installsystemd --name=milkv-bluetooth --no-stop-on-upgrade

override_dh_installman:
	dh_installman
