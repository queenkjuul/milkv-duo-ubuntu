#!/usr/bin/make -f

%:
	dh $@

override_dh_fixperms:
	dh_fixperms
	chmod +x debian/milkv-wireless-duos/usr/bin/*

override_dh_installsystemd:
	dh_installsystemd --name=milkv-wireless --no-stop-on-upgrade

override_dh_installman:
	dh_installman

clean:
	rm -rf debian/.debhelper || true
	rm -rf debian/milkv-wireless-duos || true
	rm debian/*debhelper* || true
	rm debian/*substvars* || true
	rm debian/files || true