#!/bin/bash

set -e

TTY=$1

[ -z "$TTY" ] && { 
  echo "No TTY provided for UART Bluetooth!"
  echo "Usage: milkv-bt-init <ttyS*>"
  exit 1
}

echo "Loading Bluetooth support"
modprobe bluetooth
if [ ! -d "/sys/module/aic8800_fdrv" ]; then
  milkv-wifi-init # shared driver, powers on wireless chip
fi
echo "Loading Bluetooth power management support"
modprobe aic8800_btlpm
echo "Unblocking Bluetooth"
rfkill unblock bluetooth
echo "Starting Bluetooth service on $TTY"
/usr/bin/hciattach -n -s 1500000 /dev/$TTY any 1500000 flow nosleep